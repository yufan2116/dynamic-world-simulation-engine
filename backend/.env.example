# ========== DeepSeek V4（叙事 + 意图解析，推荐） ==========
# 在 https://platform.deepseek.com 申请 API Key
DEEPSEEK_API_KEY=sk-替换为你的DeepSeek密钥

# OpenAI 兼容端点（勿改，除非官方文档更新）
OPENAI_BASE_URL=https://api.deepseek.com

# 模型：deepseek-v4-flash（快/省）或 deepseek-v4-pro（更强）
MODEL_NAME=deepseek-v4-flash

# 兼容旧变量名（可不填；若只填此项也可工作）
# OPENAI_API_KEY=

# ========== 图像生成（可选，DeepSeek 不提供绘图 API） ==========
# 若需要 AI 肖像/场景图，请使用 OpenAI 或兼容 DALL·E 的服务并填写：
# IMAGE_API_KEY=sk-...
# IMAGE_BASE_URL=https://api.openai.com/v1
# IMAGE_MODEL=dall-e-3

IMAGE_STYLE=medieval fantasy
