    "ask_thomas_last_night": {
      "player_action_echo": "你选择：「询问托马斯昨夜巡逻情况。」",
      "dice": { "ability": "CHA", "roll": 11, "modifier": 1, "total": 12, "dc": 12, "result": "success" },
      "narrative_blocks": [
        { "type": "scene", "text": "托马斯沉默片刻，才缓缓开口。" },
        { "type": "dialogue", "speaker": "托马斯", "text": "我见过马库斯。" },
        { "type": "dialogue", "speaker": "托马斯", "text": "昨晚大概二更天，他驾着马车往仓库去了。当时还下着雨，我记得很清楚。" },
        { "type": "scene", "text": "托马斯皱起眉，目光扫向仓库小路。" },
        { "type": "dialogue", "speaker": "托马斯", "text": "后来他没再回来。旧仓库方向夜里还有人影——我已加派哨岗，上面不让声张。" },
        { "type": "note", "text": "你在笔记上记下时间与方向。" },
        { "type": "clue", "text": "昨夜二更天马库斯驾车往仓库去，此后未归；仓库方向亦有人影" }
      ],
      "new_facts": [
        {
          "id": "clue_thomas_patrol",
          "text": "托马斯称昨夜二更天马库斯驾车往仓库去，此后未归；仓库方向亦有人影",
          "source": "托马斯",
          "type": "npc_statement"
        }
      ],
      "new_topics": ["warehouse_activity", "extra_patrol"],
      "npc_trust_changes": { "thomas": 1 },
      "state_changes": { "remaining_turns": -1 }
    },
    "talk_米拉": {
      "player_action_echo": "你选择：「前往酒馆向米拉打听消息。」",
      "dice": { "ability": "CHA", "roll": 13, "modifier": 1, "total": 14, "dc": 11, "result": "success" },
      "narrative_blocks": [
        { "type": "scene", "text": "酒馆里炉火噼啪作响，米拉把你拉到角落，声音压得很低。" },
        { "type": "dialogue", "speaker": "米拉", "text": "我看见守卫深夜调动——不是寻常换岗那种。" },
        { "type": "dialogue", "speaker": "米拉", "text": "马库斯最后一趟，也是往仓库方向去的。雨那么大，我忘不了那辆马车。" },
        { "type": "note", "text": "仓库、守卫、马库斯的行踪在你笔记上连成一线。" },
        { "type": "clue", "text": "守卫深夜调动，马库斯最后前往仓库" }
      ],
      "new_facts": [
        {
          "id": "clue_mira_guard",
          "text": "米拉看见守卫深夜调动，马库斯最后前往仓库方向",
          "source": "米拉",
          "type": "npc_statement"
