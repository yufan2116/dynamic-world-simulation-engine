  "outcomes": {
    "ask_elena_father_details": {
      "player_action_echo": "你选择：「安慰艾琳娜，询问她父亲最后去了哪里。」",
      "dice": { "ability": "CHA", "roll": 14, "modifier": 1, "total": 15, "dc": 12, "result": "success" },
      "narrative_blocks": [
        { "type": "scene", "text": "艾琳娜攥着裙摆，努力让自己冷静下来。" },
        { "type": "scene", "text": "艾琳娜努力回忆着。" },
        { "type": "dialogue", "speaker": "艾琳娜", "text": "父亲出门前一直念叨着那批货……他说必须今晚确认清楚，不能耽误商队启程。" },
        { "type": "dialogue", "speaker": "艾琳娜", "text": "之后就再也没有回来。" },
        { "type": "note", "text": "你将这句话记在调查笔记上。" },
        { "type": "clue", "text": "马库斯失踪前曾提到一批需要连夜确认的货物" }
      ],
      "new_facts": [
        {
          "id": "clue_elena_cargo",
          "text": "艾琳娜说父亲失踪前提到一批需要连夜确认的货物",
          "source": "艾琳娜",
          "type": "npc_statement"
        }
      ],
      "new_topics": ["cargo", "last_seen"],
      "npc_trust_changes": { "elena": 1 },
      "crisis_pressure_delta": 5,
      "state_changes": { "remaining_turns": -1 },
      "world_events": [{ "type": "npc", "text": "托马斯仍在村口警戒，似乎在留意你们的谈话。" }]
    },
    "ask_elena_cargo_detail": {
      "player_action_echo": "你选择：「追问艾琳娜那批货是什么。」",
      "dice": { "ability": "CHA", "roll": 12, "modifier": 1, "total": 13, "dc": 11, "result": "success" },
      "narrative_blocks": [
        { "type": "scene", "text": "艾琳娜深吸一口气，像是终于抓住了某个具体的锚点。" },
        { "type": "dialogue", "speaker": "艾琳娜", "text": "是商队订的布匹与铁器……父亲说必须连夜清点入库，一件都不能错。" },
        { "type": "note", "text": "你在笔记上补了一笔：货物与仓库直接相关。" },
        { "type": "clue", "text": "货物为布匹与铁器，须连夜清点入库" }
      ],
      "new_facts": [
        {
          "id": "fact_elena_cargo_detail",
          "text": "艾琳娜称货物为布匹与铁器，需连夜清点入库",
          "source": "艾琳娜",
          "type": "npc_statement"
        }
      ],
      "new_topics": ["warehouse_activity"],
      "npc_trust_changes": { "elena": 1 },
      "state_changes": { "remaining_turns": -1 }
    },
    "observe_elena_reaction": {
      "player_action_echo": "你选择：“观察艾琳娜的反应。”",
      "dice": { "ability": "WIS", "roll": 12, "modifier": 2, "total": 14, "dc": 10, "result": "success" },
      "narrative_blocks": [
        { "type": "scene", "text": "艾琳娜指尖发白，目光不断飘向仓库小路，像在等父亲从那个方向回来。" },
        { "type": "result", "text": "她的焦虑明显指向仓库与昨夜那批货。" }
      ],
      "new_observations": [
        {
          "id": "observation_elena_anxious_warehouse",
          "text": "艾琳娜频频望向仓库方向，焦虑难掩",
          "source": "player_observation",
