  "opening": {
    "narrative_blocks": [
      { "type": "scene", "text": "雨后的雷文福德笼罩在灰蓝色晨光里。木栅、火把、守卫托马斯紧皱眉头。" },
      { "type": "dialogue", "speaker": "艾琳娜", "text": "求求你们……我父亲昨晚没有回来！他是商人马库斯——" },
      { "type": "scene", "text": "广场泥水未干，村民的目光追着你的脚步。" }
    ]
  },
  "endings": {
    "ending_a_rescue": {
      "title": "马库斯获救",
      "subtitle": "你在黑森林找到了被绑的商人。",
      "epigraph": "雷文福德的雾散了。",
      "narrative_blocks": [
        { "type": "scene", "text": "瓦里克丢下武器退入雾中。马库斯被解开绳索，踉跄扑向艾琳娜。" },
        { "type": "result", "text": "失踪的商人平安归来。" }
      ]
    },
    "ending_c_coverup": {
      "title": "真相被掩盖",
      "subtitle": "时间耗尽，调查无疾而终。",
      "epigraph": "雨又下了起来。",
      "narrative_blocks": [
        { "type": "consequence", "text": "关键线索太少，马库斯的下落再无人提起。" }
      ]
    },
    "ending_d_trap": {
      "title": "误入陷阱",
      "subtitle": "你贸然闯入黑森林，落入了埋伏。",
      "epigraph": "火把在泥地里熄灭。",
      "narrative_blocks": [
        { "type": "consequence", "text": "调查中断——线索不足便闯入黑森林。" }
      ]
    }
  },
