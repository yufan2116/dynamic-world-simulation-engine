        }
      ],
      "state_changes": { "remaining_turns": -1 }
    },
    "observe_thomas_reaction": {
      "player_action_echo": "你选择：“观察托马斯的反应。”",
      "dice": { "ability": "WIS", "roll": 13, "modifier": 2, "total": 15, "dc": 11, "result": "success" },
      "narrative_blocks": [
        { "type": "scene", "text": "托马斯站在木栅旁，目光反复扫向仓库小路，指节因握紧剑柄而发白。" },
        { "type": "result", "text": "他神色紧张，像在隐瞒什么，却又不便当众开口。" },
        { "type": "consequence", "text": "获得观察：托马斯对仓库方向格外戒备。" }
      ],
      "new_observations": [
        {
          "id": "observation_thomas_nervous",
          "text": "托马斯神色紧张，频频望向仓库方向",
