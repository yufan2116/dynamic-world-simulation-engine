      "new_topics": ["warehouse_activity"],
      "state_changes": { "remaining_turns": -1 }
    },
    "inspect_村口_environment": {
      "player_action_echo": "你选择：「检查村口泥地痕迹。」",
      "dice": { "ability": "WIS", "roll": 16, "modifier": 2, "total": 18, "dc": 11, "result": "success" },
      "narrative_blocks": [
        { "type": "scene", "text": "你蹲在泥地边，膝盖沾满冰冷的泥水。" },
